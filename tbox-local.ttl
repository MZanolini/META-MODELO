                   mgmt:IcebergCompetencia, mgmt:LiderancaSituacional,
                   mgmt:GrowthMindset, mgmt:WholeBrainModel, mgmt:BMM, mgmt:PMVV .
# Anotação por instância
mgmt:LeanSixSigma prov:wasGeneratedBy ref:curadoria_chat_2026_07_23_secao1 ;
    prov:generatedAtTime "2026-07-23T00:00:00Z"^^xsd:dateTime ;
    prov:wasDerivedFrom ref:source_metamodelo_xlsx ;
    org:confidenceLevel ref:ai_generated_approved .
