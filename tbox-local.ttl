# tbox-local.ttl -- Extensoes locais de vocabulario (Camada 2.5 e bridges),
# Recorte 1: apenas os termos usados pelos 16 shapes ja validados em shapes.ttl.
# Extraido de Arquitetura_Ontologica_Empresarial_v1_3.docx.
#
# ESCOPO: isto NAO inclui gist nem ArchiMate 3.2 (ontologias externas publicadas --
# ver nota de pendencia no Mapa de Gap, item "Repositorio de ontologia"). Contem
# apenas as extensoes org:/ref:/demo:/vsm: definidas pelo proprio documento.
#
# METODO: mesmas duas correcoes mecanicas do shapes.ttl (link markdown -> URI,
# restauracao de quebra de linha comentario/statement). Zero anomalias na
# correcao de URI neste recorte.
#
# LACUNA DE CONTEUDO ENCONTRADA (nao mecanica -- nao resolvida aqui, ver nota
# no final do arquivo): org:ManagementDimension e usado em dezenas de lugares
# do documento (SPARQL, sh:in, exemplos) mas sua declaracao formal como
# owl:Class com owl:oneOf nunca aparece no texto-fonte. Nao inventei essa
# declaracao. Fica pendente de decisao do consultor.
#
# status: rascunho de extracao, recorte 1 de N. Nao valida contra dados reais.

@prefix owl:        <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:       <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:        <http://www.w3.org/2001/XMLSchema#> .
@prefix archimate:  <http://www.opengroup.org/xsd/archimate/3.2/> .
@prefix org:        <https://example.org/ontology/> .
@prefix demo:       <https://example.org/demo/> .
@prefix vsm:        <https://example.org/vsm/> .
@prefix gist:       <https://ontologies.semanticarts.com/gist/> .
@prefix ref:        <https://example.org/ref/> .
@prefix skos:       <http://www.w3.org/2004/02/skos/core#> .
@prefix mgmt:       <https://example.org/mgmt/> .
@prefix pcf:        <https://example.org/pcf/> .
@prefix naics:      <https://example.org/naics/> .
@prefix prov:       <http://www.w3.org/ns/prov#> .

### Bridge DEMO -- Secao 6

# Propriedade-ponte: BusinessProcess realiza padrão DEMO .
demo:realizesCoordinationPattern a owl:ObjectProperty ; rdfs:domain archimate:BusinessProcess ; rdfs:range demo:Transaction ; rdfs:label "realiza padrão de coordenação"@pt . 
# Classe DEMO Transaction com suas fases canônicas .
demo:Transaction a owl:Class ; rdfs:label "DEMO Transaction"@en, "Transação DEMO"@pt ; rdfs:comment "Padrão de coordenação performativa em cinco atos: request, promise, execute, state, accept."@pt .
demo:hasPhase a owl:ObjectProperty ; rdfs:domain demo:Transaction ; rdfs:range demo:TransactionPhase .
demo:TransactionPhase a owl:Class ; owl:equivalentClass [ a owl:Class ; owl:oneOf ( demo:Request demo:Promise demo:Execute demo:State demo:Accept ) ] . 
# Axioma de cobertura: todo BusinessProcess que envolve coordenação # entre dois ou mais atores deve realizar ao menos uma Transaction. 
# (Esta regra é validada em SHACL — ver §9, Shape 07.)

### Bridge VSM -- Secao 7

# Classe enumerada de funções VSM .
vsm:VSMFunction a owl:Class ; rdfs:label "Função VSM"@pt ; owl:equivalentClass [ a owl:Class ; owl:oneOf ( vsm:S1 vsm:S2 vsm:S3 vsm:S3star vsm:S4 vsm:S5 ) ] . vsm:S1 a vsm:VSMFunction ; rdfs:label "S1 — Operação primária"@pt . vsm:S2 a vsm:VSMFunction ; rdfs:label "S2 — Coordenação anti-oscilatória"@pt . vsm:S3 a vsm:VSMFunction ; rdfs:label "S3 — Regulação e sinergia"@pt . vsm:S3star a vsm:VSMFunction ; rdfs:label "S3* — Auditoria esporádica"@pt . vsm:S4 a vsm:VSMFunction ; rdfs:label "S4 — Inteligência e prospecção"@pt . vsm:S5 a vsm:VSMFunction ; rdfs:label "S5 — Política e identidade"@pt . 
# Propriedade-destino para sinais que contornam coordenação regular # (usada por org:AlgedonicAlert em §7.3 e por Shape 11 em §9) .
vsm:targetFunction a owl:ObjectProperty ; rdfs:domain gist:Event ; rdfs:range vsm:VSMFunction ; rdfs:label "função VSM de destino"@pt, "VSM target function"@en ; rdfs:comment "Função VSM à qual um sinal organizacional é dirigido — usado canonicamente por AlgedonicAlert, que aponta para S5."@pt . 
# Propriedade de anotação, domínio restrito a estrutura ativa ou comportamento .
vsm:vsmFunction a owl:ObjectProperty ; rdfs:domain [ a owl:Class ; owl:unionOf ( archimate:BusinessActor archimate:BusinessRole archimate:BusinessCollaboration archimate:BusinessFunction archimate:BusinessProcess archimate:Capability ) ] ; rdfs:range vsm:VSMFunction .

### AlgedonicAlert -- Secao 7.3

org:AlgedonicAlert a owl:Class ; rdfs:subClassOf gist:Event ; rdfs:label "Alerta algedônico"@pt ; rdfs:comment "Sinal de urgência que contorna canais regulares de coordenação"@pt . 
# Todo AlgedonicAlert tem como destino canônico S5 (Identidade) .
org:AlgedonicAlert rdfs:subClassOf [ a owl:Restriction ; owl:onProperty vsm:targetFunction ; owl:hasValue vsm:S5 ] .

### KPI / Intervention (base) -- area pre-Secao 8

ref:KPI a owl:Class ; rdfs:subClassOf gist:Magnitude ; rdfs:label "Indicador-chave de Desempenho"@pt .
ref:BSCPerspective a owl:Class ; owl:equivalentClass [ a owl:Class ; owl:oneOf ( ref:Financial ref:Customer ref:InternalProcess ref:LearningGrowth ) ] .
ref:measuresCapability a owl:ObjectProperty ; rdfs:domain ref:KPI ; rdfs:range archimate:Capability .
ref:hasBSCPerspective a owl:ObjectProperty ; rdfs:domain ref:KPI ; rdfs:range ref:BSCPerspective .
ref:hasThreshold a owl:ObjectProperty ; rdfs:domain ref:KPI ; rdfs:range ref:Threshold .
ref:Threshold a owl:Class ; rdfs:label "Faixa de Tolerância"@pt .
ref:greenUpperBound a owl:DatatypeProperty ; rdfs:range xsd:decimal .
ref:yellowUpperBound a owl:DatatypeProperty ; rdfs:range xsd:decimal . 
# acima de yellow → vermelho → dispara org:AlgedonicAlert (ver §7.3) # Intervenção com ROI rastreável
ref:Intervention a owl:Class ; rdfs:subClassOf gist:Project ; rdfs:label "Intervenção Consultiva"@pt .
ref:appliesFramework a owl:ObjectProperty ; rdfs:domain ref:Intervention ; rdfs:range ref:ManagementFramework .
ref:targetsCapability a owl:ObjectProperty ; rdfs:domain ref:Intervention ; rdfs:range archimate:Capability .
ref:investmentCost a owl:DatatypeProperty ; rdfs:domain ref:Intervention ; rdfs:range xsd:decimal .
ref:realizedReturn a owl:DatatypeProperty ; rdfs:domain ref:Intervention ; rdfs:range xsd:decimal .

### Competencia Humana (vocabulario) -- Secao 8.9.1

ref:Competence a owl:Class ; rdfs:label "Competência Humana"@pt ; rdfs:comment "Habilidade requerida por uma pessoa para executar microatividades e compor capabilities organizacionais."@pt . 
# Tres subclasses CHA
ref:TechnicalCompetence rdfs:subClassOf ref:Competence ; rdfs:label "Competência Técnica (Conhecimento aplicado)"@pt .
ref:BehavioralCompetence rdfs:subClassOf ref:Competence ; rdfs:label "Competência Comportamental (Atitude)"@pt .
ref:ManagerialCompetence rdfs:subClassOf ref:Competence ; rdfs:label "Competência Gerencial (Habilidade integradora)"@pt . 
# Competencia tem ancoragem dimensional
ref:anchoredInDimension a owl:ObjectProperty ; rdfs:domain ref:Competence ; rdfs:range org:ManagementDimension . 
# Capability requer competencias (matriz ponderada)
org:capabilityRequiresCompetence a owl:ObjectProperty ; rdfs:domain archimate:Capability ; rdfs:range ref:Competence .
org:competenceWeight a owl:DatatypeProperty ; rdfs:range xsd:decimal ; rdfs:comment "Peso (0-100) da competencia na composicao da capability; soma por capability = 100."@pt .

### Papeis de Mudanca -- Secao 8.12.2

ref:ChangeSponsor a owl:Class ;
    rdfs:subClassOf archimate:BusinessRole ;
    rdfs:label "Patrocinador de Mudança"@pt ;
    rdfs:comment "Papel executivo com autoridade formal e capital político para autorizar, financiar e remover obstáculos à Intervention."@pt .
ref:ChangeAgent a owl:Class ;
    rdfs:subClassOf archimate:BusinessRole ;
    rdfs:label "Agente de Mudança"@pt ;
    rdfs:comment "Papel operacional responsável por planejar e executar atividades de mudança no perímetro da Intervention."@pt .
ref:ChangeEndUser a owl:Class ;
    rdfs:subClassOf archimate:BusinessRole ;
    rdfs:label "Usuário Final da Mudança"@pt ;
    rdfs:comment "Papel cujo comportamento ou processo é alterado pela Intervention."@pt .
ref:ChangeResistor a owl:Class ;
    rdfs:subClassOf archimate:BusinessRole ;
    rdfs:label "Papel Resistente à Mudança"@pt ;
    rdfs:comment "Papel identificado como fonte de resistência. Atribuição é diagnóstica — informa estratégia de engajamento — e refere-se a papéis, não a indivíduos nomeados (§8.12.1)."@pt .

### Status e Ciclo de Intervention -- Secao 8.12.3

ref:InterventionStatus a owl:Class ;
    rdfs:label "Status de Intervention"@pt ;
    owl:equivalentClass [
        a owl:Class ;
        owl:oneOf ( ref:Proposed ref:Approved ref:InProgress ref:Concluded ref:Cancelled )
    ] .
ref:Proposed   a ref:InterventionStatus ; rdfs:label "Proposta"@pt .
ref:Approved   a ref:InterventionStatus ; rdfs:label "Aprovada (não iniciada)"@pt .
ref:InProgress a ref:InterventionStatus ; rdfs:label "Em execução"@pt .
ref:Concluded  a ref:InterventionStatus ; rdfs:label "Concluída (ROI realizado declarável)"@pt .
ref:Cancelled  a ref:InterventionStatus ; rdfs:label "Cancelada"@pt .
ref:interventionStatus a owl:ObjectProperty ;
    rdfs:domain ref:Intervention ;
    rdfs:range  ref:InterventionStatus .

### Avaliacao de Prontidao -- Secao 8.12.5

ref:ChangeReadinessAssessment a owl:Class ;
    rdfs:label "Avaliação de Prontidão para Mudança"@pt ;
    rdfs:comment "Snapshot de readiness organizacional para uma Intervention, com estrutura definida pela metodologia adotada."@pt .
ref:byMethodology a owl:ObjectProperty ;
    rdfs:domain ref:ChangeReadinessAssessment ;
    rdfs:range  ref:ManagementFramework ;
    rdfs:comment "Metodologia de mudança que define as fases avaliadas neste assessment (ex: mgmt:ADKAR)."@pt .
ref:assessmentScope a owl:ObjectProperty ;
    rdfs:domain ref:ChangeReadinessAssessment ;
    rdfs:range  archimate:Capability ;
    rdfs:comment "Capability-alvo cuja Intervention este assessment habilita."@pt .
ref:assessedAt a owl:DatatypeProperty ;
    rdfs:domain ref:ChangeReadinessAssessment ;
    rdfs:range  xsd:dateTime .
ref:assessedBy a owl:ObjectProperty ;
    rdfs:domain ref:ChangeReadinessAssessment ;
    rdfs:range  archimate:BusinessRole .

# Score reificado por fase — vocabulário invariante; fases concretas são instâncias curadas
ref:PhaseScore a owl:Class ;
    rdfs:label "Score de Fase"@pt ;
    rdfs:comment "Reificação que liga um Assessment a uma fase específica com seu score numérico."@pt .
ref:phaseScore a owl:ObjectProperty ;
    rdfs:domain ref:ChangeReadinessAssessment ;
    rdfs:range  ref:PhaseScore .
ref:onPhase a owl:ObjectProperty ;
    rdfs:domain ref:PhaseScore ;
    rdfs:range  ref:FrameworkPhase ;
    rdfs:comment "Fase do framework metodológico (ex: mgmt:ADKAR_Awareness) à qual o score se refere."@pt .
ref:score a owl:DatatypeProperty ;
    rdfs:domain ref:PhaseScore ;
    rdfs:range  xsd:integer ;
    rdfs:comment "Score numérico atribuído à fase. Escala e critérios definidos pela metodologia da Camada 2.5."@pt .

### Vinculos com Intervention -- Secao 8.12.6

ref:hasSponsor a owl:ObjectProperty ;
    rdfs:domain ref:Intervention ;
    rdfs:range  ref:ChangeSponsor ;
    rdfs:comment "Patrocinador formal da Intervention (cardinalidade >= 1 imposta em §9 Shape 15)."@pt .
ref:hasChangeAgent a owl:ObjectProperty ;
    rdfs:domain ref:Intervention ;
    rdfs:range  ref:ChangeAgent .
ref:engagesStakeholder a owl:ObjectProperty ;
    rdfs:domain ref:Intervention ;
    rdfs:range  archimate:Stakeholder ;
    rdfs:comment "Stakeholder ArchiMate (camada motivacional) com interesse declarado na Intervention."@pt .
ref:hasChangeReadiness a owl:ObjectProperty ;
    rdfs:domain ref:Intervention ;
    rdfs:range  ref:ChangeReadinessAssessment ;
    rdfs:comment "Assessment de prontidão habilitador da Intervention. Cardinalidade condicional ao status (§9 Shape 16)."@pt .
ref:appliesChangeMethodology a owl:ObjectProperty ;
    rdfs:domain ref:Intervention ;
    rdfs:range  ref:ManagementFramework ;
    rdfs:comment "Metodologia de change management adotada. Distinta de ref:appliesFramework, que aponta para o framework de gestão central (ex: DMAIC, OKR)."@pt .

### org:ManagementDimension -- PROVISORIO, decisao do consultor em 2026-07-01
# Declaracao ausente no texto-fonte (usada em dezenas de lugares, nunca formalizada).
# Forma abaixo espelha o padrao ja usado por ref:InterventionStatus (Secao 8.12.3) e
# ref:MaturityLevel (Secao 8.1.1) no proprio documento -- nao e reuso de gist/ArchiMate
# (checagem contra gist real ainda pendente -- gist.owl nao importado, Passo 5 do
# roteiro). GATILHO DE REVISAO: quando gist.owl for importado, reconciliar contra
# qualquer classe de classificacao equivalente antes de tratar como definitivo.
org:ManagementDimension a owl:Class ;
    rdfs:label "Dimensão de Gestão"@pt ;
    rdfs:comment "As seis dimensões gerenciais cruzadas com perspectivas ArchiMate na matriz 6x6 (ver Secao 1)."@pt ;
    owl:equivalentClass [
        a owl:Class ;
        owl:oneOf ( org:Identidade org:Direcao org:Operacao org:Recursos org:Controle org:Evolucao )
    ] .

org:Identidade a org:ManagementDimension ; rdfs:label "Identidade"@pt .
org:Direcao    a org:ManagementDimension ; rdfs:label "Direção"@pt .
org:Operacao   a org:ManagementDimension ; rdfs:label "Operação"@pt .
org:Recursos   a org:ManagementDimension ; rdfs:label "Recursos"@pt .
org:Controle   a org:ManagementDimension ; rdfs:label "Controle"@pt .
org:Evolucao   a org:ManagementDimension ; rdfs:label "Evolução"@pt .

### ============================================================
### RECORTE 2 — Mesclado em 2026-07-01
### Adicionado ao tbox-local.ttl (previamente commit 820974d).
### Vocabulário pcf:, naics:, mgmt:, e ref:Microactivity/FrameworkPhase.
### Fonte: Arquitetura_Ontologica_Empresarial_v1_3 §8.3/§8.4/§8.7/§8.11/§8.12.8.
### PROVISÓRIOS INCLUÍDOS: mgmt:LeanSixSigma, mgmt:OKR (ver nota 5 do bloco).
### Cabeçalho original do recorte 2 preservado abaixo — contém decisões de escopo.
### ============================================================

# ============================================================
# tbox-recorte2-additions.ttl
# Adições ao TBox local — Recorte 2: vocabulário pcf:, naics:,
# mgmt:, e Microactivity/FrameworkPhase.
#
# Fonte: Arquitetura_Ontologica_Empresarial_v1_3.docx
#   §8.3.2-8.3.3  mgmt: catálogo de frameworks (classe abstrata,
#                 6 subclasses por natureza, Domain, instâncias)
#   §8.4          pcf: taxonomia PCF/APQC (classes + propriedades)
#   §8.7          naics: classificação setorial (classe + propriedades)
#   §8.11.1       Microactivity / FrameworkPhase (vocabulário)
#   §8.12.8       mgmt: catálogo — metodologias de mudança (ADKAR,
#                 Kotter8Steps, ScheinCultureModel + fases ADKAR)
#
# Extraído por: Claude (sessão de chat), 2026-07-01.
# Status: NÃO commitado. Pendente de reposicionamento e
#   revalidação independente pelo Cowork antes de commit no
#   repositório real (mesmo fluxo do recorte 1 — ver
#   Handoff_Curadoria_Camada25_v0_1.md).
# Alvo de merge: destina-se a ser ANEXADO ao tbox-local.ttl
#   existente (commit 820974d), não é um arquivo standalone
#   novo — usa os mesmos prefixos ref:/org:/gist:/archimate:.
#
# DECISÕES DE ESCOPO DESTA EXTRAÇÃO (não são decisão do
# consultor — registradas aqui para revisão, revisáveis):
#
# 1. EXCLUÍDO — instâncias de exemplo em pcf:/naics:
#    (pcf:n_11_0, pcf:n_11_1, pcf:n_11_1_1_1_1 de §8.4;
#    naics:522110, naics:336111 de §8.7). São dado de catálogo
#    externo (ABox de referência), não vocabulário (TBox).
#    Migram junto da curadoria de conteúdo real (Frente D).
#    Nota lateral: naics:522110 é rotulado "Commercial Banking"
#    no texto-fonte — setor regulado, fora do posicionamento do
#    consultor. Como o exemplo não foi extraído, isso não afeta
#    este arquivo; fica como observação para quando a Arquitetura
#    for revisada (Frente A).
#
# 2. EXCLUÍDO — exemplo de Microactivity de §8.11.2
#    (ref:atv_020_F1_01, mgmt:DMAIC_F1_Define usado com
#    ref:realizesCapability apontando para data:cap_reducao_variacao
#    e data:cmp_six_sigma_dmaic). Referencia data: — é ABox de
#    tenant, não vocabulário.
#
# 3. INCLUÍDO — mgmt:DMAIC_F1_Define (ao contrário do item 2,
#    só a declaração da fase, sem o exemplo de Microactivity
#    associado). É instância de catálogo mgmt: (ref:FrameworkPhase),
#    mesmo padrão que mgmt:ADKAR_Awareness etc. — o próprio
#    texto-fonte (§8.12.8) chama isso de "padrão idêntico".
#    Fases F2-F5 do DMAIC (Measure/Analyze/Improve/Control) NÃO
#    existem como instâncias no texto-fonte v1.3 — não foram
#    inventadas aqui. Gap de curadoria futura.
#
# 4. EXCLUÍDO — as 3 regras de roteamento semântico de §8.8.2
#    (ref:RR_VariabilityToDMAIC, ref:RR_AdaptabilityToScrum,
#    ref:RR_StrategyGapToOKR — sh:NodeShape com SPARQL). Não são
#    vocabulário; são regras executáveis. Não fazem parte da
#    contagem oficial de 16 shapes de §9 (essas vieram do recorte
#    1). Candidato a recorte futuro separado.
#
# 5. PROVISÓRIO — mgmt:LeanSixSigma e mgmt:OKR. Usados
#    repetidamente no texto-fonte (§8.5, §8.8.2, §8.12.6, §8.12.9,
#    §11.7, glossário §15) mas NUNCA declarados formalmente —
#    ambiguidade genuína, não corrupção mecânica (mesmo padrão do
#    precedente org:ManagementDimension no recorte 1). Declarados
#    abaixo como ref:Methodology por decisão explícita do
#    consultor (2026-07-01), por analogia ao uso idêntico de
#    mgmt:DMAIC/mgmt:Scrum nas regras de roteamento (excluídas
#    por este arquivo, ver item 4, mas presentes no texto-fonte).
#    GATILHO DE REVISÃO: quando a Metodologia consultiva formalizar
#    o catálogo real desses frameworks (Frente C) — reconciliar ou
#    promover a definitivo.
#
# 6. DEPENDÊNCIAS EXTERNAS NÃO DECLARADAS NESTE ARQUIVO — referenciadas
#    via rdfs:domain/range mas fora do escopo nomeado deste recorte:
#    archimate:Capability, archimate:BusinessProcess, gist:Organization
#    (já importados por gist/ArchiMate); org:ManagementDimension e
#    seus indivíduos org:Operacao/org:Controle/org:Direcao/org:Evolucao
#    (recorte 1, provisório); ref:MaturityLevel e seus indivíduos
#    ref:Initial/ref:Repeatable/ref:Defined (§8.1.1, não extraído em
#    nenhum recorte até agora); ref:GapType e seus indivíduos
#    ref:HighVariability/ref:LowAdaptability/ref:StrategyExecutionGap
#    (§8.8.1, não extraído); ref:Competence (§8.9.1, não extraído);
#    ref:Artifact (§8.5, não extraído). Este arquivo NÃO é
#    standalone-completo — pyshacl/rdflib vão parsear sem erro
#    (URIs não resolvidas não quebram Turtle), mas qualquer
#    reasoning ou SHACL que dependa dessas classes precisa dos
#    recortes correspondentes.
# ============================================================


# ------------------------------------------------------------
# §8.3.2 — Catálogo de Frameworks de Gestão
# ------------------------------------------------------------

ref:ManagementFramework a owl:Class ;
    rdfs:subClassOf gist:Specification ;
    rdfs:label "Framework de Gestao (abstrato)"@pt .

ref:ManagementSystem    rdfs:subClassOf ref:ManagementFramework .
ref:Methodology         rdfs:subClassOf ref:ManagementFramework .
ref:Technique           rdfs:subClassOf ref:ManagementFramework .
ref:Standard            rdfs:subClassOf ref:ManagementFramework .
ref:ConceptualModel     rdfs:subClassOf ref:ManagementFramework .
ref:AnalyticalFramework rdfs:subClassOf ref:ManagementFramework .

ref:applicableDomain a owl:ObjectProperty ;
    rdfs:domain ref:ManagementFramework ;
    rdfs:range ref:Domain .

ref:Lean       a ref:Domain ; rdfs:label "Lean / Eficiencia operacional"@pt .
ref:Quality    a ref:Domain ; rdfs:label "Qualidade"@pt .
ref:Agile      a ref:Domain ; rdfs:label "Agilidade / Iteracao"@pt .
ref:Strategic  a ref:Domain ; rdfs:label "Estrategia"@pt .
ref:Governance a ref:Domain ; rdfs:label "Governanca"@pt .
ref:Operations a ref:Domain ; rdfs:label "Operacoes"@pt .
ref:People     a ref:Domain ; rdfs:label "Pessoas e Cultura"@pt .
ref:Finance    a ref:Domain ; rdfs:label "Financas"@pt .

# Propriedades de aplicabilidade (mantidas da v1.1).
# Ranges abaixo apontam para classes fora do escopo deste recorte
# — ver nota 6 do cabeçalho.
ref:addressesGapType rdfs:domain ref:ManagementFramework ;
    rdfs:range ref:GapType .

ref:applicableInDimension rdfs:domain ref:ManagementFramework ;
    rdfs:range org:ManagementDimension .

ref:requiresMinimumMaturity rdfs:domain ref:ManagementFramework ;
    rdfs:range ref:MaturityLevel .

ref:decomposesIntoPCFNode rdfs:domain ref:ManagementFramework ;
    rdfs:range pcf:PCFNode .

# ------------------------------------------------------------
# §8.4 — PCF/APQC como Taxonomia de Referência
# Licenciamento: PCF distribuído pela APQC sob CC-BY 4.0,
# atribuição requerida em qualquer interface que renderize
# identificadores PCF. Validação jurídica do uso comercial
# permanece pendente (fora do escopo desta extração).
# ------------------------------------------------------------

pcf:PCFNode a owl:Class ;
    rdfs:label "Nó PCF (qualquer nível)"@pt .

pcf:ProcessCategory rdfs:subClassOf pcf:PCFNode ;
    rdfs:label "Categoria (Nível 1)"@pt .

pcf:ProcessGroup rdfs:subClassOf pcf:PCFNode ;
    rdfs:label "Grupo de Processos (Nível 2)"@pt .

pcf:Process rdfs:subClassOf pcf:PCFNode ;
    rdfs:label "Processo (Nível 3)"@pt .

pcf:Activity rdfs:subClassOf pcf:PCFNode ;
    rdfs:label "Atividade (Nível 4)"@pt .

pcf:Task rdfs:subClassOf pcf:PCFNode ;
    rdfs:label "Tarefa (Nível 5)"@pt .

pcf:identifier a owl:DatatypeProperty ;
    rdfs:domain pcf:PCFNode ;
    rdfs:range xsd:string ;
    rdfs:comment "Identificador APQC dotted (ex: '11.1.1.1.1')"@pt .

pcf:apqcCode a owl:DatatypeProperty ;
    rdfs:domain pcf:PCFNode ;
    rdfs:range xsd:string ;
    rdfs:comment "Código APQC entre parênteses (ex: '23023')"@pt .

pcf:parentNode a owl:ObjectProperty ;
    rdfs:domain pcf:PCFNode ;
    rdfs:range pcf:PCFNode .

# Ponte com ArchiMate — tenant declara que seu processo realiza um nó PCF
org:realizesPCFNode a owl:ObjectProperty ;
    rdfs:domain archimate:BusinessProcess ;
    rdfs:range pcf:PCFNode .

# ------------------------------------------------------------
# §8.7 — Multi-tenancy e Classificação Setorial (NAICS)
# ------------------------------------------------------------

naics:Industry a owl:Class ;
    rdfs:subClassOf skos:Concept ;
    rdfs:label "Setor Industrial NAICS"@pt .

naics:naicsCode a owl:DatatypeProperty ;
    rdfs:domain naics:Industry ;
    rdfs:range xsd:string .

org:industryCode a owl:ObjectProperty ;
    rdfs:domain gist:Organization ;
    rdfs:range naics:Industry .

# ------------------------------------------------------------
# §8.11.1 — Microactivity / FrameworkPhase
# ------------------------------------------------------------

ref:Microactivity a owl:Class ;
    rdfs:subClassOf gist:Specification ;
    rdfs:label "Microatividade"@pt ;
    rdfs:comment "Acao executavel de literatura framework, granularidade abaixo de pcf:Task."@pt .

ref:FrameworkPhase a owl:Class ;
    rdfs:label "Fase de Framework"@pt ;
    rdfs:comment "Subdivisao temporal de um framework (ex: Define/Measure/Analyze/Improve/Control do DMAIC)."@pt .

ref:phaseOfFramework a owl:ObjectProperty ;
    rdfs:domain ref:FrameworkPhase ;
    rdfs:range ref:ManagementFramework .

ref:partOfFrameworkPhase a owl:ObjectProperty ;
    rdfs:domain ref:Microactivity ;
    rdfs:range ref:FrameworkPhase .

ref:realizesCapability a owl:ObjectProperty ;
    rdfs:domain ref:Microactivity ;
    rdfs:range archimate:Capability .

ref:involvesEntity a owl:ObjectProperty ;
    rdfs:domain ref:Microactivity .

ref:producesAnalyticalObject a owl:ObjectProperty ;
    rdfs:domain ref:Microactivity .

ref:requiresCompetence a owl:ObjectProperty ;
    rdfs:domain ref:Microactivity ;
    rdfs:range ref:Competence .

ref:instrumentedByArtifact a owl:ObjectProperty ;
    rdfs:domain ref:Microactivity ;
    rdfs:range ref:Artifact .

ref:bibliographicSource a owl:DatatypeProperty ;
    rdfs:domain ref:Microactivity ;
    rdfs:range xsd:string ;
    rdfs:comment "Fonte literatura/manual de origem (ex: 'ASQ DMAIC Body of Knowledge')."@pt .

# ------------------------------------------------------------
# §8.3.3 + §8.12.8 — Catálogo mgmt: (instâncias de framework)
# mgmt: não contém classes — só indivíduos nomeados das classes
# ref: declaradas acima. Herança múltipla é permitida e ocorre
# (ex: mgmt:ISO9001, mgmt:TOC).
# ------------------------------------------------------------

mgmt:DMAIC a ref:Methodology ;
    rdfs:label "DMAIC — Define, Measure, Analyze, Improve, Control"@pt ;
    ref:applicableDomain ref:Quality, ref:Operations ;
    ref:addressesGapType ref:HighVariability ;
    ref:applicableInDimension org:Operacao, org:Controle ;
    ref:requiresMinimumMaturity ref:Repeatable .

mgmt:ISO9001 a ref:Standard, ref:ManagementSystem ;
    rdfs:label "ISO 9001 — Sistemas de Gestao da Qualidade"@pt ;
    ref:applicableDomain ref:Quality, ref:Governance ;
    ref:requiresMinimumMaturity ref:Defined .

mgmt:Porter5Forces a ref:AnalyticalFramework ;
    rdfs:label "Cinco Forcas de Porter"@pt ;
    ref:applicableDomain ref:Strategic ;
    ref:applicableInDimension org:Direcao ;
    ref:requiresMinimumMaturity ref:Initial .

mgmt:TOC a ref:ConceptualModel, ref:ManagementSystem ;
    rdfs:label "Theory of Constraints (Goldratt)"@pt ;
    ref:applicableDomain ref:Operations ;
    ref:applicableInDimension org:Operacao .

mgmt:Scrum a ref:Methodology ;
    rdfs:label "Scrum"@pt ;
    ref:applicableDomain ref:Agile ;
    ref:addressesGapType ref:LowAdaptability ;
    ref:applicableInDimension org:Evolucao, org:Operacao .

mgmt:ADKAR a ref:Methodology ;
    rdfs:label "ADKAR — Awareness, Desire, Knowledge, Ability, Reinforcement"@pt ;
    ref:applicableDomain ref:People ;
    ref:addressesGapType ref:StrategyExecutionGap ;
    ref:requiresMinimumMaturity ref:Initial .

mgmt:Kotter8Steps a ref:Methodology ;
    rdfs:label "Oito Passos de Kotter para Liderar Mudança"@pt ;
    ref:applicableDomain ref:People, ref:Strategic ;
    ref:requiresMinimumMaturity ref:Repeatable .

mgmt:ScheinCultureModel a ref:ConceptualModel ;
    rdfs:label "Modelo de Cultura Organizacional (Schein)"@pt ;
    ref:applicableDomain ref:People ;
    rdfs:comment "Lente diagnóstica de pressupostos básicos, valores expostos e artefatos visíveis."@pt .

# Fases (ref:FrameworkPhase) do catálogo mgmt:

mgmt:DMAIC_F1_Define a ref:FrameworkPhase ;
    rdfs:label "DMAIC F1 — Define"@pt ;
    ref:phaseOfFramework mgmt:DMAIC .
# Fases F2-F5 (Measure/Analyze/Improve/Control) NÃO existem como
# instâncias no texto-fonte v1.3 — gap de curadoria futura, não
# inventado aqui.

mgmt:ADKAR_Awareness a ref:FrameworkPhase ;
    rdfs:label "ADKAR — Awareness (Consciência)"@pt ;
    ref:phaseOfFramework mgmt:ADKAR .

mgmt:ADKAR_Desire a ref:FrameworkPhase ;
    rdfs:label "ADKAR — Desire (Desejo)"@pt ;
    ref:phaseOfFramework mgmt:ADKAR .

mgmt:ADKAR_Knowledge a ref:FrameworkPhase ;
    rdfs:label "ADKAR — Knowledge (Conhecimento)"@pt ;
    ref:phaseOfFramework mgmt:ADKAR .

mgmt:ADKAR_Ability a ref:FrameworkPhase ;
    rdfs:label "ADKAR — Ability (Habilidade)"@pt ;
    ref:phaseOfFramework mgmt:ADKAR .

mgmt:ADKAR_Reinforcement a ref:FrameworkPhase ;
    rdfs:label "ADKAR — Reinforcement (Reforço)"@pt ;
    ref:phaseOfFramework mgmt:ADKAR .

# --- PROVISÓRIO — ver nota 5 do cabeçalho. Decisão do consultor,
# 2026-07-01: declarar como ref:Methodology. Gatilho de revisão:
# formalização do catálogo pela Metodologia consultiva (Frente C).

mgmt:LeanSixSigma a ref:Methodology ;
    rdfs:label "Lean Six Sigma"@pt ;
    ref:applicableDomain ref:Lean, ref:Quality, ref:Operations ;
    ref:applicableInDimension org:Operacao, org:Controle .

mgmt:OKR a ref:Methodology ;
    rdfs:label "OKR — Objectives and Key Results"@pt ;
    ref:applicableDomain ref:Strategic ;
    ref:applicableInDimension org:Direcao, org:Controle .

mgmt:LeanThinking a ref:Methodology ;
    rdfs:label "Lean Thinking / Toyota Production System"@pt ;
    ref:applicableDomain ref:Lean, ref:Operations ;
    ref:applicableInDimension org:Operacao .

mgmt:EOS a ref:ManagementSystem ;
    rdfs:label "EOS — Entrepreneurial Operating System"@pt ;
    ref:applicableDomain ref:Strategic, ref:Governance ;
    ref:applicableInDimension org:Identidade, org:Direcao .

mgmt:IcebergCompetencia a ref:ConceptualModel ;
    rdfs:label "Iceberg da Competência do Gestor (McClelland / Spencer & Spencer)"@pt ;
    ref:applicableDomain ref:People ;
    ref:applicableInDimension org:Identidade, org:Recursos .

mgmt:LiderancaSituacional a ref:ConceptualModel ;
    rdfs:label "Liderança Situacional (Hersey & Blanchard)"@pt ;
    ref:applicableDomain ref:People ;
    ref:applicableInDimension org:Identidade, org:Recursos .

mgmt:GrowthMindset a ref:ConceptualModel ;
    rdfs:label "Growth Mindset (Carol Dweck)"@pt ;
    ref:applicableDomain ref:People ;
    ref:applicableInDimension org:Identidade, org:Evolucao .

mgmt:WholeBrainModel a ref:ConceptualModel ;
    rdfs:label "Whole Brain Model (Herrmann)"@pt ;
    ref:applicableDomain ref:People ;
    ref:applicableInDimension org:Identidade, org:Recursos .

mgmt:BMM a ref:AnalyticalFramework ;
    rdfs:label "Business Motivation Model (OMG)"@pt ;
    ref:applicableDomain ref:Strategic, ref:Governance ;
    ref:applicableInDimension org:Identidade, org:Direcao .

mgmt:PMVV a ref:Technique ;
    rdfs:label "Purpose-Mission-Vision-Values (Bain)"@pt ;
    ref:applicableDomain ref:Strategic, ref:People ;
    ref:applicableInDimension org:Identidade .

### ============================================================
### RECORTE 3 — Mesclado em 2026-07-08
### Adicionado ao tbox-local.ttl (previamente commit d5eaa13).
### Vocabulário ref:MaturityLevel (§8.1.1), ref:GapType (§8.8.1),
### ref:Artifact (§8.5). Fonte: Arquitetura_Ontologica_Empresarial_v1_3.
###
### NOTA DE ESCOPO — §8.9.1 (ref:Competence) NÃO consta deste bloco:
### já foi extraído no Recorte 1 (linhas 77-85, commit 820974d).
### "Reuso > criação": não redeclarado aqui. CORREÇÃO DE REGISTRO: a linha
### do checklist do Registro e a nota 6 do cabeçalho do Recorte 2 marcavam
### §8.9.1 como "não extraído" — impreciso; estava presente desde Recorte 1.
### Labels de §8.9.1 no Recorte 1 estão SEM acento; normalização acentuada
### decidida pelo consultor fica pendente de relabel (não aplicada a conteúdo
### já commitado sem confirmação explícita) — ver Registro §1.
###
### PENDÊNCIA (a) — ref:ReferenceCapability: §8.1.1 declara
### org:targetMaturityLevel com rdfs:domain ref:ReferenceCapability, classe
### cuja definição completa é de §8.2 (Recorte 3 ou 4, em aberto no Registro).
### Opção adotada = (i) stub mínimo owl:Class + comment. Opção (ii) =
### referência implícita sem declarar a classe. Decisão na validação (Registro §1).
###
### RESOLVIDO NO RECORTE 4 (commit f09dc6a): definição completa de
### ref:ReferenceCapability adicionada, ver bloco §8.2 abaixo.
###
### PONTO (b) — ref:Methodology × ref:ManagementFramework: relação JÁ
### declarada (ref:Methodology rdfs:subClassOf ref:ManagementFramework,
### bloco Recorte 2). Logo mgmt:LeanSixSigma/mgmt:OKR (ref:Methodology) são
### transitivamente ref:ManagementFramework e o range de ref:partOfFramework
### (§8.5) é satisfeito. Sem inconsistência a corrigir.
### ============================================================

# ------------------------------------------------------------
# §8.1.1 — Escala canônica de Maturidade (5 níveis)
# ------------------------------------------------------------
ref:MaturityLevel a owl:Class ;
    rdfs:label "Nível de Maturidade"@pt ;
    owl:equivalentClass [ a owl:Class ; owl:oneOf ( ref:Initial ref:Repeatable ref:Defined ref:Managed ref:Optimized ) ] .
ref:Initial    a ref:MaturityLevel ; ref:levelOrder 1 ; rdfs:label "1 — Inicial (reativo, caótico)"@pt .
ref:Repeatable a ref:MaturityLevel ; ref:levelOrder 2 ; rdfs:label "2 — Repetível (sucesso depende de heróis)"@pt .
ref:Defined    a ref:MaturityLevel ; ref:levelOrder 3 ; rdfs:label "3 — Definido (padronizado e documentado)"@pt .
ref:Managed    a ref:MaturityLevel ; ref:levelOrder 4 ; rdfs:label "4 — Gerenciado (medido quantitativamente)"@pt .
ref:Optimized  a ref:MaturityLevel ; ref:levelOrder 5 ; rdfs:label "5 — Otimizado (melhoria contínua)"@pt .
ref:levelOrder a owl:DatatypeProperty ; rdfs:domain ref:MaturityLevel ; rdfs:range xsd:integer .

org:hasMaturityLevel a owl:ObjectProperty ;
    rdfs:domain [ a owl:Class ; owl:unionOf ( archimate:Capability archimate:BusinessProcess archimate:BusinessFunction ) ] ;
    rdfs:range ref:MaturityLevel ;
    rdfs:comment "Maturidade observada (as-is)"@pt .

# §8.2 — Definição completa de ReferenceCapability
# (substitui o stub mínimo do Recorte 3; ver nota "RESOLVIDO NO RECORTE 4" acima).
ref:ReferenceCapability a owl:Class ;
    rdfs:subClassOf archimate:Capability ;
    rdfs:label "Capability de Referência"@pt ;
    rdfs:comment "Capacidade-padrão curada para um setor e nível-alvo de maturidade"@pt .
ref:applicableIndustry a owl:ObjectProperty ;
    rdfs:domain ref:ReferenceCapability ;
    rdfs:range naics:Industry .
ref:realizedByReferenceProcess a owl:ObjectProperty ;
    rdfs:domain ref:ReferenceCapability ;
    rdfs:range pcf:Process ;
    rdfs:comment "Processos PCF que realizam canonicamente esta capability"@pt .
org:hasReferenceCapability a owl:ObjectProperty ;
    rdfs:domain archimate:Capability ;
    rdfs:range ref:ReferenceCapability .
# §8.2.1 — Subclasses setoriais
ref:DiscreteManufacturingCapability rdfs:subClassOf ref:ReferenceCapability ;
    rdfs:label "Capability de Referência — Manufatura Discreta"@pt ;
    rdfs:comment "Setor inicial de curadoria; foco em middle market industrial brasileiro."@pt .
ref:ProfessionalServicesCapability rdfs:subClassOf ref:ReferenceCapability ;
    rdfs:label "Capability de Referência — Serviços Profissionais"@pt .
ref:DistributionWholesaleCapability rdfs:subClassOf ref:ReferenceCapability ;
    rdfs:label "Capability de Referência — Distribuição/Atacado"@pt .
ref:RetailCapability rdfs:subClassOf ref:ReferenceCapability ;
    rdfs:label "Capability de Referência — Varejo"@pt .
ref:applicableSector a owl:ObjectProperty ;
    rdfs:domain ref:ReferenceCapability ;
    rdfs:range naics:Industry .
org:targetMaturityLevel a owl:ObjectProperty ;
    rdfs:domain ref:ReferenceCapability ;
    rdfs:range ref:MaturityLevel ;
    rdfs:comment "Maturidade desejada para o nível-alvo da referência (to-be)"@pt .

# ------------------------------------------------------------
# §8.8.1 — Tipos de Gap Diagnosticado (7 subtipos)
# ------------------------------------------------------------
ref:GapType a owl:Class ; rdfs:label "Tipo de Gap Diagnosticado"@pt .
ref:HighVariability      a ref:GapType ; rdfs:label "Variabilidade alta"@pt .
ref:LongLeadTime         a ref:GapType ; rdfs:label "Lead time excessivo"@pt .
ref:LowAdaptability      a ref:GapType ; rdfs:label "Baixa adaptabilidade ao ambiente"@pt .
ref:StrategyExecutionGap a ref:GapType ; rdfs:label "Estratégia não-executada"@pt .
ref:ControlFailure       a ref:GapType ; rdfs:label "Falha de controle / risco materializado"@pt .
ref:SupplyDemandMismatch a ref:GapType ; rdfs:label "Descoordenação supply × demand"@pt .
ref:KnowledgeAttrition   a ref:GapType ; rdfs:label "Perda de conhecimento crítico"@pt .
org:gapType a owl:ObjectProperty ;
    rdfs:domain archimate:Capability ;
    rdfs:range ref:GapType ;
    rdfs:comment "Diagnóstico atribuído à capability do tenant após análise as-is"@pt .

# ------------------------------------------------------------
# §8.5 — Biblioteca de Artefatos (10 subclasses)
# ------------------------------------------------------------
ref:Artifact a owl:Class ;
    rdfs:subClassOf gist:Specification ;
    rdfs:label "Artefato Consultivo"@pt .
ref:FMEAWorksheet  rdfs:subClassOf ref:Artifact .
ref:CTQTree        rdfs:subClassOf ref:Artifact .
ref:SIPOCDiagram   rdfs:subClassOf ref:Artifact .
ref:ValueStreamMap rdfs:subClassOf ref:Artifact .
ref:RACIMatrix     rdfs:subClassOf ref:Artifact .
ref:OKRSheet       rdfs:subClassOf ref:Artifact .
ref:BSCDashboard   rdfs:subClassOf ref:Artifact .
ref:CanvasBMC      rdfs:subClassOf ref:Artifact .
ref:DMAICTemplate  rdfs:subClassOf ref:Artifact .
ref:RiskHeatmap    rdfs:subClassOf ref:Artifact .
ref:instrumentsTask a owl:ObjectProperty ; rdfs:domain ref:Artifact ; rdfs:range pcf:PCFNode .
ref:templateURL     a owl:DatatypeProperty ; rdfs:domain ref:Artifact ; rdfs:range xsd:anyURI .
ref:partOfFramework a owl:ObjectProperty ; rdfs:domain ref:Artifact ; rdfs:range ref:ManagementFramework .
### FIM DO RECORTE 3 ###

### ============================================================
### RECORTE 4 — Mesclado em 2026-07-20
### Base: commit 52f7017 (Recorte 3). Fonte: Arquitetura_Ontologica_Empresarial_v1_3.
### §8.12.4 (ref:ResistanceFactor + 5 subclasses + 3 propriedades) e
### §8.12.7 (5 subclasses de ref:Artifact para artefatos de mudança).
###
### NOTA DE REUSO ("reuso > criação"):
### - ref:ChangeResistor (§8.12.2, domain de exhibitsResistance) e
###   ref:Intervention (§8.12.3/§8.12.6, range de affectsIntervention) já foram
###   extraídos no Recorte 1 — NÃO redeclarados aqui.
### - ref:Artifact (§8.5) já foi extraído no Recorte 3 — as 5 subclasses de
###   §8.12.7 apenas herdam dele, sem propriedades novas.
###
### OBSERVAÇÃO DE CONTEÚDO (novo item no Registro §1, não decidida):
### ref:applicableIndustry (§8.2) e ref:applicableSector (§8.2.1) têm domain e
### range idênticos (ref:ReferenceCapability → naics:Industry). A fonte só
### diferencia dizendo que o segundo é "mais granular", sem detalhar. Extraídas
### as duas exatamente como estão, sem fundir nem renomear.
###
### A definição completa de §8.2 + §8.2.1 (ref:ReferenceCapability) foi aplicada
### NO LUGAR do stub, dentro do bloco RECORTE 3 acima — não neste bloco.
### ============================================================

# ------------------------------------------------------------
# §8.12.4 — Fatores de Resistência à Mudança
# ------------------------------------------------------------
ref:ResistanceFactor a owl:Class ;
    rdfs:label "Fator de Resistência à Mudança"@pt .
ref:CulturalResistance a owl:Class ; rdfs:subClassOf ref:ResistanceFactor ;
    rdfs:label "Resistência Cultural"@pt ;
    rdfs:comment "Pressupostos básicos compartilhados (Schein) que conflitam com a mudança."@pt .
ref:PoliticalResistance a owl:Class ; rdfs:subClassOf ref:ResistanceFactor ;
    rdfs:label "Resistência Política"@pt ;
    rdfs:comment "Perda percebida de poder, território, autonomia ou orçamento."@pt .
ref:CognitiveResistance a owl:Class ; rdfs:subClassOf ref:ResistanceFactor ;
    rdfs:label "Resistência Cognitiva"@pt ;
    rdfs:comment "Não-entendimento do racional, modelo mental incompatível, ceticismo informacional."@pt .
ref:EmotionalResistance a owl:Class ; rdfs:subClassOf ref:ResistanceFactor ;
    rdfs:label "Resistência Emocional"@pt ;
    rdfs:comment "Medo de incompetência, perda de identidade profissional, ansiedade."@pt .
ref:CapacityResistance a owl:Class ; rdfs:subClassOf ref:ResistanceFactor ;
    rdfs:label "Resistência por Capacidade"@pt ;
    rdfs:comment "Falta concreta de tempo, recurso ou habilidade — diferente de falta de vontade."@pt .
ref:exhibitsResistance a owl:ObjectProperty ; rdfs:domain ref:ChangeResistor ; rdfs:range ref:ResistanceFactor .
ref:affectsIntervention a owl:ObjectProperty ; rdfs:domain ref:ResistanceFactor ; rdfs:range ref:Intervention .
ref:resistanceSeverity a owl:DatatypeProperty ; rdfs:domain ref:ResistanceFactor ; rdfs:range xsd:integer ;
    rdfs:comment "Severidade estimada (1-5). Escala invariante; critérios de avaliação curados pela Metodologia."@pt .

# ------------------------------------------------------------
# §8.12.7 — Artefatos de Mudança Organizacional (herdam de ref:Artifact §8.5)
# ------------------------------------------------------------
ref:CommunicationPlan    rdfs:subClassOf ref:Artifact ; rdfs:label "Plano de Comunicação de Mudança"@pt .
ref:StakeholderMap       rdfs:subClassOf ref:Artifact ; rdfs:label "Mapa de Stakeholders (poder x interesse)"@pt .
ref:SponsorshipChecklist rdfs:subClassOf ref:Artifact ; rdfs:label "Checklist de Patrocínio Executivo"@pt .
ref:ResistanceLog        rdfs:subClassOf ref:Artifact ; rdfs:label "Registro de Resistências e Respostas"@pt .
ref:ChangeTrainingPlan   rdfs:subClassOf ref:Artifact ; rdfs:label "Plano de Capacitação para a Mudança"@pt .
### FIM DO RECORTE 4 ###

### ============================================================
### RECORTE 5 — Mesclado em 2026-07-23
### Vocabulário de proveniência de curadoria e confidence level.
### Fonte: Arquitetura_Ontologica_Empresarial_v1_3 §13.5 e §13.6.
### Prefixo prov: já consta na tabela normativa de namespaces (§4),
### não requer RFC de namespace.
### DECISÃO PROVISÓRIA: o nome da classe ref:ConfidenceLevel não
### consta na fonte; adotado por analogia a ref:InterventionStatus
### (§8.12.3). Quinta enumeração fechada do arquivo — mesmo gatilho
### de revisão dos itens 1 e 8 do Registro (importação real do
### gist.owl). Ver Registro §1 item 15.
### ============================================================
# ------------------------------------------------------------
# §13.6 — Confidence levels (enumeração fechada)
# ------------------------------------------------------------
ref:ConfidenceLevel a owl:Class ;
    rdfs:label "Nível de Confiança"@pt ;
    owl:oneOf ( ref:peer_reviewed_source ref:human_curated
                ref:ai_generated_approved ref:ai_generated ) .
ref:peer_reviewed_source a ref:ConfidenceLevel ;
    rdfs:label "Fonte revisada por pares"@pt ;
    rdfs:comment "Tripla derivada de fonte externa revisada por pares ou manual oficial. Contexto autoritativo, peso pleno."@pt .
ref:human_curated a ref:ConfidenceLevel ;
    rdfs:label "Curado por humano"@pt ;
    rdfs:comment "Tripla escrita ou revisada e aprovada diretamente por humano sênior, sem geração por IA. Contexto autoritativo, peso pleno."@pt .
ref:ai_generated_approved a ref:ConfidenceLevel ;
    rdfs:label "Gerado por IA e aprovado"@pt ;
    rdfs:comment "Tripla gerada por IA, aprovada em validação estrutural e por humano. Contexto válido com peso reduzido (sugestão inicial 0.5)."@pt .
ref:ai_generated a ref:ConfidenceLevel ;
    rdfs:label "Gerado por IA, não aprovado"@pt ;
    rdfs:comment "Tripla gerada por IA ainda não aprovada. Nunca incluída como contexto autoritativo."@pt .
org:confidenceLevel a owl:ObjectProperty ;
    rdfs:range ref:ConfidenceLevel ;
    rdfs:label "Nível de confiança da tripla"@pt ;
    rdfs:comment "rdfs:domain deliberadamente não declarado: aplica-se a qualquer sujeito curado (instância de framework, capability, artefato). §13.6."@pt .
# ------------------------------------------------------------
# §13.5 — Proveniência de curadoria
# Atividades e fontes usam prov:Activity e prov:Entity diretamente,
# sem classe local. Padrão leve da §13.5, deliberadamente distinto
# do template de pipeline do Manual §6.5 (curation-run/bundle com
# hash), que é gerado por código e não deve ser escrito à mão.
# ------------------------------------------------------------
ref:sourceType a owl:DatatypeProperty ;
    rdfs:range xsd:string ;
    rdfs:comment "Tipo da fonte de evidência (ex.: 'peer_reviewed_book', 'acervo_interno'). Literal por ora, conforme §13.5."@pt .
### FIM DO RECORTE 5 ###

